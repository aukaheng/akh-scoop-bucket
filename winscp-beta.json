{
  "version": "6.6.1",
  "homepage": "https://sourceforge.net/projects/winscp/files/WinSCP/",
  "url": "https://downloads.sourceforge.net/project/winscp/WinSCP/6.6.1%20beta/WinSCP-6.6.1.beta-Portable.zip",
  "hash": "AC582381C133D4FED4DDC9C857137B820376B124E64AE5380E06E1BDA7DF63EE",
  "pre_install": [
    "if (!(Test-Path \"$persist_dir\\winscp.ini\")) {",
    "    @(",
    "        '[Configuration\\Interface]'",
    "        'RandomSeedFile=.\\winscp.rnd'",
    "    ) | Add-Content -Path \"$dir\\winscp.ini\" -Encoding ASCII -Force",
    "}"
  ],
  "bin": [
    "WinSCP.exe",
    [
      "WinSCP.com",
      "WinSCP-cli"
    ]
  ],
  "shortcuts": [
    [
      "WinSCP.exe",
      "WinSCP"
    ]
  ],
  "persist": "winscp.ini"
}
