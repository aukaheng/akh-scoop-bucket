{
  "version": "6.6.2",
  "homepage": "https://sourceforge.net/projects/winscp/files/WinSCP/",
  "url": "https://downloads.sourceforge.net/project/winscp/WinSCP/6.6.2%20RC/WinSCP-6.6.2.RC-Portable.zip",
  "hash": "A20940DF166BE6FC895172C84CCE0D8EF9363B7988836AE321C8F564D7C1FF46",
  "pre_install": [
    "if (!(Test-Path \"$persist_dir\\winscp.ini\")) {",
    "    @(",
    "        '[Configuration\\Interface]'",
    "        'RandomSeedFile=.\\winscp.rnd'",
    "    ) | Add-Content -Path \"$dir\\winscp.ini\" -Encoding ASCII -Force",
    "}"
  ],
  "bin": [
    "WinSCP.exe",
    [
      "WinSCP.com",
      "WinSCP-cli"
    ]
  ],
  "shortcuts": [
    [
      "WinSCP.exe",
      "WinSCP"
    ]
  ],
  "persist": "winscp.ini"
}
