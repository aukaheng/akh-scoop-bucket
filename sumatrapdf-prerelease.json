    "    Write-Host 'File' $file 'does not exists. Creating.' -f Yellow",
    "    $CONT = @('CheckForUpdates = false')",
    "    Set-Content \"$dir\\$file\" ($CONT -join \"`r`n\") -Encoding Ascii",
    "}"
  ],
  "bin": [
